Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  cppcoreguidelines-*,
  misc-*,
  -google-*,
  -llvm-*,
  -boost-*,
  -fuchsia-*,
  -zircon-*,
  -android-*,
  -abseil-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-pro-type-union-access

WarningsAsErrors: ''
HeaderFilterRegex: '^(src|include)/'
FormatStyle: none
